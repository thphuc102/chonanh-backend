generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Album {
  id                String   @id @default(uuid())
  title             String
  customerName      String?
  customerEmail     String?
  customerPhone     String?
  coverImage        String?
  imageCount        Int      @default(0)
  size              String?
  status            String   @default("Mới")
  date              String?
  creator           String?
  creatorId         String?
  creatorEmail      String?
  domain            String?
  driveLink         String?
  downloadDriveLink String?
  finalDriveLink    String?
  tags              String[]
  shootDate         String?
  shootLocation     String?
  password          String?
  expiryDate        String?
  landingCover      String?
  landingAvatar     String?
  landingFooter     String?
  selectionStatus   String?  @default("selecting")
  selectionLockedAt String?
  priceLink         String?
  zaloLink          String?
  totalViews        Int      @default(0)
  maxSelections     Int?
  createdAt         String?

  // Nested JSON objects are native to Postgres Prisma
  settings          Json?

  photos            Photo[]
}

model Photo {
  id           String   @id @default(uuid())
  albumId      String
  url          String
  createdAt    String
  likes        Int      @default(0)
  tags         String[]
  favorite     Boolean  @default(false)
  commentCount Int      @default(0)
  status       String   @default("active")
  price        Float?

  album        Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
}
